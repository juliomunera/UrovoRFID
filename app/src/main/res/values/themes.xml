<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Light.NoActionBar: fuerza siempre el tema claro.
        Reemplaza DayNight.NoActionBar que activaba modo oscuro
        automáticamente según la configuración del sistema.
    -->
    <style name="Theme.UrovoRFID" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">#1565C0</item>
        <item name="colorPrimaryVariant">#0D47A1</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#42A5F5</item>
        <item name="colorOnSecondary">#000000</item>
        <item name="android:statusBarColor">#0D47A1</item>

        <!-- Fondo de ventana siempre blanco -->
        <item name="android:windowBackground">#FFFFFF</item>

        <!-- Colores de superficie siempre claros -->
        <item name="colorSurface">#FFFFFF</item>
        <item name="colorOnSurface">#212121</item>

        <!-- NavigationView fondo blanco -->
        <item name="navigationViewStyle">@style/NavViewStyle</item>

        <!-- CardView fondo blanco -->
        <item name="cardViewStyle">@style/CardViewStyle</item>

        <!-- EditText texto oscuro sobre fondo claro -->
        <item name="android:editTextColor">#212121</item>
        <item name="android:textColorHint">#9E9E9E</item>
    </style>

    <style name="NavViewStyle" parent="Widget.MaterialComponents.NavigationView">
        <item name="android:background">#FFFFFF</item>
        <item name="itemTextColor">#212121</item>
        <item name="itemIconTint">#1565C0</item>
    </style>

    <style name="CardViewStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">#FFFFFF</item>
        <item name="cardElevation">2dp</item>
    </style>
</resources>
